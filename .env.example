# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=8889
DB_DATABASE=se_entry
DB_USERNAME=root
DB_PASSWORD=root
# Lokal MAMP: pakai socket. Hostinger: KOSONGKAN agar db.js memakai host+port.
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# ── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_EXPIRES_IN=30m
BCRYPT_ROUNDS=10

# Akun admin awal yang dibuat skrip seed (ganti di produksi).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_MITRA_USERNAME=mitra
SEED_MITRA_PASSWORD=mitra123

# ── Enkripsi answers (fase akhir — §7.1; ditunda) ───────────────────────────
# ENCRYPTION_KEY=<32-byte base64>

# ── MCP (Model Context Protocol) ────────────────────────────────────────────
# MCP server di-mount di /mcp (GET = SSE, POST = JSON-RPC 2.0).
# Dua cara autentikasi:
#   1. Bearer JWT  — gunakan token dari POST /api/auth/login
#   2. X-Api-Key   — set MCP_API_KEY di bawah, kirim sebagai header X-Api-Key
MCP_ENABLED=true
# Opsional: kunci statis untuk akses mesin-ke-mesin (AI agent, Claude Desktop, dsb.)
# Biarkan kosong untuk hanya mengizinkan JWT.
# MCP_API_KEY=ganti-dengan-kunci-acak-panjang
